# =============================================================================
# AISpark Studio — Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# All variables use the AISPARK_ prefix (handled by pydantic-settings).
# =============================================================================

# Core
AISPARK_SECRET_KEY=your-secret-key-here          # Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AISPARK_DEBUG_MODE=false
AISPARK_LOG_LEVEL=INFO

# CORS — comma-separated origins
AISPARK_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501

# Database
# SQLite (local development, no Docker):
AISPARK_DATABASE_URL=sqlite:///./aispark_studio.db
# PostgreSQL (Docker / production):
# AISPARK_DATABASE_URL=postgresql+psycopg2://aispark:aispark_dev@localhost:5432/aispark_studio

# Google AI — API key (fallback if no service account)
AISPARK_GOOGLE_API_KEY=your-google-api-key-here
AISPARK_AI_MODEL_NAME=gemini-2.5-flash
AISPARK_AI_TEMPERATURE=0.8
AISPARK_AI_MAX_TOKENS=2048

# Google Custom Search (optional)
AISPARK_GOOGLE_SEARCH_ENABLED=false
AISPARK_GOOGLE_CSE_API_KEY=your-cse-api-key-here
AISPARK_GOOGLE_CSE_CX=your-cse-cx-here

# Vertex AI Search (RAG pipeline)
AISPARK_VERTEX_SEARCH_ENABLED=false
AISPARK_VERTEX_PROJECT_ID=your-gcp-project-id
AISPARK_VERTEX_LOCATION=global
AISPARK_VERTEX_DATA_STORE_ID=your-datastore-id
AISPARK_VERTEX_ENGINE_ID=your-engine-id
AISPARK_VERTEX_SERVING_CONFIG=default_search
AISPARK_VERTEX_GEN_LOCATION=us-central1

# Google Cloud Authentication
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# B2B Sandbox & Admin (optional)
AISPARK_SANDBOX_API_KEY=
AISPARK_ADMIN_API_KEY=

# Feature Flags
AISPARK_ENABLE_RAG=true
AISPARK_ENABLE_DIVERSITY=true
AISPARK_ENABLE_SELF_CRITIQUE=true

# Caching
AISPARK_ENABLE_CACHE=true
AISPARK_CACHE_TTL=1800
AISPARK_CACHE_MAX_SIZE=1000

# Redis (cache consolidation)
# REDIS_URL=redis://localhost:6379/0

# Docker Compose (override defaults in docker-compose.yml)
# POSTGRES_USER=aispark
# POSTGRES_PASSWORD=aispark_dev
# POSTGRES_DB=aispark_studio
